# Database
DATABASE_URI=postgresql://torrentio:password@localhost:5432/torrentio

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Server
PORT=7000
NODE_ENV=development

# Cache
CACHE_MAX_AGE=3600

# Metrics (optional)
METRICS_USER=admin
METRICS_PASSWORD=changeme

# MongoDB (optional, for additional caching)
MONGODB_URI=mongodb://localhost:27017/torrentio
